generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  GOOGLE
  CREDENTIALS
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  imageUrl  String?
  password  String?
  provider  AuthProvider
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}